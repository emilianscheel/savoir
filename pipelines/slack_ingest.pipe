{
    "name": "slack_ingest",
    "description": "Optional local-dev enrichment pipeline. Production ingestion uses Butterbase enrich_and_merge function. webhook -> extract_data (LLM) -> HTTP merge.",
    "nodes": [
        {
            "id": "source_1",
            "provider": "webhook"
        },
        {
            "id": "extract_1",
            "provider": "extract_data",
            "config": {
                "instructions": [
                    "Extract summary and topics from each Slack message in the batch JSON."
                ],
                "parameters": {}
            },
            "input": [
                {
                    "lane": "text",
                    "from": "source_1"
                }
            ]
        },
        {
            "id": "llm_1",
            "provider": "llm_openai",
            "config": {
                "profile": "openai-4o-mini",
                "openai-4o-mini": {
                    "apikey": "${ROCKETRIDE_OPENAI_KEY}"
                },
                "parameters": {}
            },
            "control": [
                {
                    "classType": "llm",
                    "from": "extract_1"
                }
            ]
        },
        {
            "id": "http_1",
            "provider": "tool_http_request",
            "config": {
                "type": "tool_http_request"
            },
            "control": [
                {
                    "classType": "tool",
                    "from": "extract_1"
                }
            ]
        }
    ]
}
