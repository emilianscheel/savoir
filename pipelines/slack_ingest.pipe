{
    "components": [
        {
            "id": "source_1",
            "provider": "webhook",
            "config": {}
        },
        {
            "id": "extract_1",
            "provider": "extract_data",
            "config": {
                "instructions": [
                    "The input is JSON for a Slack message with slack_message_id, text, and channel_name.",
                    "Produce a concise summary (1-2 sentences) and 0-5 lowercase topic tags.",
                    "Output JSON only: {\"slack_message_id\":\"...\",\"summary\":\"...\",\"topics\":[\"tag1\",\"tag2\"]}"
                ],
                "parameters": {}
            },
            "input": [
                {
                    "lane": "text",
                    "from": "source_1"
                }
            ]
        },
        {
            "id": "llm_1",
            "provider": "llm_openai",
            "config": {
                "profile": "openai-4o-mini",
                "openai-4o-mini": {
                    "apikey": "${ROCKETRIDE_OPENAI_KEY}"
                },
                "parameters": {}
            },
            "control": [
                {
                    "classType": "llm",
                    "from": "extract_1"
                }
            ]
        },
        {
            "id": "target_1",
            "provider": "response_text",
            "config": {},
            "input": [
                {
                    "lane": "text",
                    "from": "extract_1"
                }
            ]
        }
    ],
    "source": "source_1",
    "name": "slack_ingest",
    "description": "Slack enrichment: webhook → extract_data → LLM → response to bridge.",
    "project_id": "7c4e9a2b-1d3f-4a8e-9b6c-2f5d8e1a0c3b",
    "viewport": { "x": 0, "y": 0, "zoom": 1 },
    "version": 1
}
