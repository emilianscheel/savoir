{
    "name": "slack_ingest",
    "description": "Cloud RocketRide enrichment pipeline. Butterbase POSTs Slack messages to the webhook source; LLM enriches; merge callback lands in Neo4j via enrich_and_merge.",
    "source": "source_1",
    "nodes": [
        {
            "id": "source_1",
            "provider": "webhook"
        },
        {
            "id": "extract_1",
            "provider": "extract_data",
            "config": {
                "instructions": [
                    "From the Slack message JSON, extract summary and 0-5 topic tags.",
                    "Input fields: slack_message_id, text, channel_name, merge_callback_url.",
                    "Output JSON: {\"slack_message_id\":\"...\",\"summary\":\"...\",\"topics\":[\"...\"],\"merge_only\":true}"
                ],
                "parameters": {}
            },
            "input": [
                {
                    "lane": "text",
                    "from": "source_1"
                }
            ]
        },
        {
            "id": "llm_1",
            "provider": "llm_openai",
            "config": {
                "profile": "openai-4o-mini",
                "openai-4o-mini": {
                    "apikey": "${ROCKETRIDE_OPENAI_KEY}"
                },
                "parameters": {}
            },
            "control": [
                {
                    "classType": "llm",
                    "from": "extract_1"
                }
            ]
        }
    ]
}
