# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored, so secrets never get pushed.

# --- Butterbase (public, safe in the browser) ---
NEXT_PUBLIC_BUTTERBASE_APP_ID=app_xxxxxxxxxxxx
NEXT_PUBLIC_BUTTERBASE_API_URL=https://api.butterbase.ai

# --- Slack app (set on Butterbase function envVars when deploying) ---
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_SIGNING_SECRET=
# SLACK_REDIRECT_URI=https://api.butterbase.ai/v1/{app_id}/fn/slack_oauth_callback
# SESSION_JWT_SECRET=          # random 32+ bytes, signs browser session JWT
# INTERNAL_CRON_SECRET=          # protects ingest/enrich internal calls
# FUNCTIONS_BASE_URL=https://api.butterbase.ai/v1/{app_id}/fn
# FRONTEND_URL=https://your-app.butterbase.dev
# INGEST_MAX_MESSAGES=500

# --- Neo4j Aura (graph storage + bot context) ---
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_READ_ONLY=true

# --- Nebius LLM (OpenAI-compatible; used by Butterbase functions) ---
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.us-central1.nebius.com/v1
NEBIUS_MODEL=moonshotai/Kimi-K2.7-Code

# --- Fallback LLM if Nebius not configured ---
OPENAI_API_KEY=

# --- RocketRide (optional cloud enrichment pipeline) ---
# Butterbase POSTs to ROCKETRIDE_WEBHOOK_URL (bridge /ingest). Bridge uses RocketRide SDK + Nebius fallback.
ROCKETRIDE_URI=https://api.rocketride.ai
ROCKETRIDE_AUTH=
ROCKETRIDE_TOKEN=
ROCKETRIDE_WEBHOOK_URL=
ROCKETRIDE_BRIDGE_SECRET=
ROCKETRIDE_BRIDGE_PORT=8787
ROCKETRIDE_OPENAI_KEY=
