# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored, so secrets never get pushed.

# --- Butterbase (public, safe in the browser) ---
NEXT_PUBLIC_BUTTERBASE_APP_ID=app_xxxxxxxxxxxx
NEXT_PUBLIC_BUTTERBASE_API_URL=https://api.butterbase.ai

# --- Neo4j Aura (shared memory graph; used by the neo4j MCP server) ---
# Values are in the Aura credentials file / team password manager.
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
# The MCP server runs read-only by default. Set to false only if agents must write.
NEO4J_READ_ONLY=true

# --- RocketRide (AI pipeline engine; used by the rocketride MCP server) ---
# ws://localhost:5565 when running the engine locally via the IDE extension.
ROCKETRIDE_URI=ws://localhost:5565
ROCKETRIDE_AUTH=

# --- LLM key referenced by pipelines/*.pipe (e.g. chat.pipe) ---
OPENAI_API_KEY=
