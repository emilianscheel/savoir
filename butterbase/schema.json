{
  "tables": {
    "slack_workspaces": {
      "columns": {
        "id": {
          "type": "uuid",
          "primaryKey": true,
          "default": "gen_random_uuid()"
        },
        "slack_team_id": {
          "type": "text",
          "nullable": false,
          "unique": true
        },
        "team_name": {
          "type": "text",
          "nullable": false
        },
        "bot_user_id": {
          "type": "text",
          "nullable": true
        },
        "bot_access_token": {
          "type": "text",
          "nullable": true
        },
        "events_verified_at": {
          "type": "timestamptz",
          "nullable": true
        },
        "created_at": {
          "type": "timestamptz",
          "default": "now()"
        },
        "updated_at": {
          "type": "timestamptz",
          "default": "now()"
        }
      },
      "indexes": {
        "slack_workspaces_team_idx": {
          "columns": ["slack_team_id"],
          "unique": true
        }
      }
    },
