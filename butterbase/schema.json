{
  "tables": {
    "accounts": {
      "columns": {
        "id": {
          "type": "uuid",
          "primaryKey": true,
          "default": "gen_random_uuid()"
        },
        "email": {
          "type": "text",
          "nullable": false,
          "unique": true
        },
        "plan": {
          "type": "text",
          "nullable": false,
          "default": "'free'"
        },
        "status": {
          "type": "text",
          "nullable": false,
          "default": "'active'"
        },
        "created_at": {
          "type": "timestamptz",
          "default": "now()"
        }
      },
      "indexes": {
        "accounts_email_idx": {
          "columns": ["email"],
          "unique": true
        }
      }
    }
  }
}
